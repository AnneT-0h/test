# Utility command for edit_cache

build cmake/stm32cubemx/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /workspaces/CubeIDE/build/Debug/cmake/stm32cubemx && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build cmake/stm32cubemx/edit_cache: phony cmake/stm32cubemx/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build cmake/stm32cubemx/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /workspaces/CubeIDE/build/Debug/cmake/stm32cubemx && /usr/bin/cmake --regenerate-during-build -S/workspaces/CubeIDE -B/workspaces/CubeIDE/build/Debug
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build cmake/stm32cubemx/rebuild_cache: phony cmake/stm32cubemx/CMakeFiles/rebuild_cache.util

# =============================================================================
# Target aliases.

build FreeRTOS: phony cmake/stm32cubemx/FreeRTOS

build STM32_Drivers: phony cmake/stm32cubemx/STM32_Drivers

build bugface: phony bugface.elf

# =============================================================================
# Folder targets.

# =============================================================================

#############################################
# Folder: /workspaces/CubeIDE/build/Debug

build all: phony bugface.elf cmake/stm32cubemx/all

# =============================================================================

#############################################
# Folder: /workspaces/CubeIDE/build/Debug/cmake/stm32cubemx

build cmake/stm32cubemx/all: phony cmake/stm32cubemx/STM32_Drivers cmake/stm32cubemx/FreeRTOS

# =============================================================================
# Built-in targets


